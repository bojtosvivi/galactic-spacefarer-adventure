{
  "_version": "1.65.0",
  "sap.app": {
    "id": "galactic.spacefarers",
    "type": "application",
    "title": "Galactic Spacefarer Adventure",
    "description": "List Report and Object Page for Galactic Spacefarers",
    "dataSources": {
      "mainService": {
        "uri": "/galactic/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "SpacefarersList",
          "target": "SpacefarersList"
        },
        {
          "pattern": "Spacefarers({key}):?query:",
          "name": "SpacefarersObjectPage",
          "target": "SpacefarersObjectPage"
        }
      ],
      "targets": {
        "SpacefarersList": {
          "type": "Component",
          "id": "SpacefarersList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Spacefarers",
              "variantManagement": "Page",
              "navigation": {
                "Spacefarers": {
                  "detail": {
                    "route": "SpacefarersObjectPage"
                  }
                }
              }
            }
          }
        },
        "SpacefarersObjectPage": {
          "type": "Component",
          "id": "SpacefarersObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/Spacefarers"
            }
          }
        }
      }
    }
  }
}
