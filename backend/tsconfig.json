{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "#cds-models/*": ["./@cds-models/*"]
    }
  },
  "include": [
    "srv/**/*.ts",
    "types/**/*.d.ts",
    "@cds-models/**/*.ts",
    "test/**/*.ts"
  ]
}
